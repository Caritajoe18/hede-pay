# ── Required: Hedera credentials (get free testnet account at https://portal.hedera.com) ──
ACCOUNT_ID="0.0.xxxxx"
PRIVATE_KEY="0x..."

# ── Hedera network (testnet | mainnet) ──
HEDERA_NETWORK=testnet

# ── LLM provider (pick one) ──
# Option A – local Ollama
USE_OLLAMA=true
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434 # or https://ollama.com if using ollama cloud server
OLLAMA_API_KEY=

HCS_TOPIC_ID=0.0.9298689
PORT=